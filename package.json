{
  "name": "windedvertigo",
  "private": true,
  "packageManager": "npm@11.8.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:creaseworks": "npm run dev -w apps/creaseworks",
    "build:creaseworks": "npm run build -w apps/creaseworks",
    "dev:vault": "npm run dev -w apps/vertigo-vault",
    "build:vault": "npm run build -w apps/vertigo-vault",
    "dev:deep-deck": "npm run dev -w apps/deep-deck",
    "build:deep-deck": "npm run build -w apps/deep-deck",
    "dev:depth-chart": "npm run dev -w apps/depth-chart",
    "build:depth-chart": "npm run build -w apps/depth-chart",
    "dev:raft": "npm run dev -w apps/raft-house",
    "build:raft": "npm run build -w apps/raft-house",
    "dev:harbour": "npm run dev -w apps/harbour",
    "build:harbour": "npm run build -w apps/harbour",
    "dev:tidal-pool": "npm run dev -w apps/tidal-pool",
    "build:tidal-pool": "npm run build -w apps/tidal-pool",
    "dev:paper-trail": "npm run dev -w apps/paper-trail",
    "build:paper-trail": "npm run build -w apps/paper-trail",
    "dev:mirror-log": "npm run dev -w apps/mirror-log",
    "build:mirror-log": "npm run build -w apps/mirror-log",
    "test": "npm run test -w apps/creaseworks",
    "test:a11y": "npm run test:a11y -w apps/creaseworks",
    "lint": "npm run lint -w apps/creaseworks"
  },
  "dependencies": {
    "@notionhq/client": "^2.3.0",
    "node-fetch": "^3.3.2"
  },
  "optionalDependencies": {
    "@next/swc-linux-arm64-gnu": "^16.2.0"
  },
  "devDependencies": {
    "turbo": "^2.8.13"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "fast-xml-parser": "5.5.8"
  }
}
