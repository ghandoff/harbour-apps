{
  "$schema": "node_modules/wrangler/config-schema.json",
  // creaseworks eval — P1.5 VERIFICATION CANARY (feature/mini-arc-redesign).
  //
  // A SEPARATE worker from the live eval tool (wv-harbour-creaseworks-eval):
  // a different name and, crucially, NO domain routes — so it reaches ONLY its
  // *.workers.dev URL and can never take over
  // windedvertigo.com/harbour/creaseworks-eval. The collective's live eval tool
  // keeps running merged code until an explicit go to deploy the real worker.
  //
  // It binds the SAME EVAL_DB + MATERIAL_ICONS as the live eval on purpose: the
  // point is to exercise the P1.5 material-dials classifier + review flow
  // against the real (migration-008) schema before the live deploy. The 008
  // columns are additive, so live eval reading them is a no-op meanwhile.
  //
  // Deploy (CW_EVAL=1 → basePath /harbour/creaseworks-eval):
  //   CW_EVAL=1 npx opennextjs-cloudflare build
  //   && node ../../packages/security/scripts/write-assets-headers.mjs /harbour/creaseworks-eval
  //   && npx wrangler deploy --config wrangler.eval-canary.jsonc
  "name": "wv-harbour-creaseworks-eval-canary",
  "main": "worker.eval.ts",

  // NO routes — workers.dev only. Do not add domain routes here.
  "account_id": "097c92553b268f8360b74f625f6d980a",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],

  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },

  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "wv-harbour-creaseworks-eval-canary"
    }
  ],

  "d1_databases": [
    {
      "binding": "EVAL_DB",
      "database_name": "wv-creaseworks-eval",
      "database_id": "b4588191-32cd-491c-b221-512c6772a90c"
    }
  ],

  "r2_buckets": [
    {
      "binding": "MATERIAL_ICONS",
      "bucket_name": "creaseworks-material-icons"
    }
  ],

  "workers_dev": true
}
