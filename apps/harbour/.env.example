# Notion
NOTION_TOKEN=ntn_...
NOTION_DEPTH_CHART_DB_ID=...
NOTION_WEBHOOK_SECRET=...

# database (Vercel Postgres / Neon — used by feedback package)
POSTGRES_URL=postgresql://...

# feedback (Slack notifications via the unified "winded.vertigo" bot)
# As of 2026-05-25, all workers post via chat.postMessage with bot token +
# channel ID. Legacy SLACK_FEEDBACK_WEBHOOK_URL has been deleted.
# The bot's scopes include chat:write.public, so it can post to public
# channels without being invited. Private channels need /invite.
SLACK_BOT_TOKEN=xoxb-...
SLACK_FEEDBACK_CHANNEL=C0AQZ6KNHSA  # #harbour-feedback

# app
NEXT_PUBLIC_APP_URL=https://windedvertigo.com/harbour
