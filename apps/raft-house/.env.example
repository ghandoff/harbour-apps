# Notion
NOTION_API_KEY=ntn_...

# database (Vercel Postgres / Neon)
POSTGRES_URL=postgresql://...

# auth
AUTH_SECRET=...
INITIAL_ADMIN_EMAIL=garrett@windedvertigo.com

# Google OAuth
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# email (Resend — used for magic links)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@windedvertigo.com

# Stripe (live keys for production, test keys for dev)
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Real-time multiplayer runs on the same Cloudflare Worker as this app via
# PartyServer (Durable Objects). The client connects same-origin to
# /harbour/raft-house/parties/raft-room/<code> — no host env var needed.

# feedback (optional — Slack notifications)
SLACK_FEEDBACK_WEBHOOK_URL=https://hooks.slack.com/...
SLACK_BOT_TOKEN=xoxb-...
SLACK_FEEDBACK_CHANNEL=C...

# app
NEXT_PUBLIC_APP_URL=https://windedvertigo.com/harbour/raft-house
