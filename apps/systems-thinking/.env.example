# systems-thinking environment variables
#
# copy to .env.local for local dev. all values must also be set in vercel
# (production + preview) and in partykit (`npx partykit env add NAME`).

# ── upstash redis (existing) ───────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── realtime (partykit) ────────────────────────────────────
# host without protocol. local dev: localhost:1999
# production: systems-thinking.<your-partykit-user>.partykit.dev
PARTYKIT_HOST=localhost:1999

# shared secret used by /api/session/{join,log,config} when posting
# events into the room. must match the value set via:
#   npx partykit env add PARTYKIT_INTERNAL_SECRET
# generate with: openssl rand -hex 32
PARTYKIT_INTERNAL_SECRET=
