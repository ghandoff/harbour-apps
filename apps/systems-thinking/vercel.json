{
  "outputDirectory": ".",
  "ignoreCommand": "npx turbo-ignore @windedvertigo/systems-thinking",
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
