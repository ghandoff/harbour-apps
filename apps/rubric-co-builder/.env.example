# neon postgres (shared with the rest of the monorepo — uses rubric_cobuilder schema)
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# anthropic (optional — for AI-generated sample artefacts)
ANTHROPIC_API_KEY=

# CF Workers local dev — copy to .dev.vars (gitignored) with real values
# wrangler secret put POSTGRES_URL
# wrangler secret put ANTHROPIC_API_KEY
